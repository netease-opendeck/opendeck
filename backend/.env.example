# OpenClaw 项目根目录（必填）
OPENCLAW_ROOT=/path/to/openclaw

# skills 相对路径，默认 workspace/skills
# OPENCLAW_SKILLS_PATH=workspace/skills

# skill-execution 文件路径（相对 OPENCLAW_ROOT），默认 workspace/tracker-result/skill-execution.jsonl
# OPENCLAW_SKILL_EXECUTION_PATH=workspace/tracker-result/skill-execution.jsonl

# 可选，服务端口，默认 19520
# PORT=19520
