#!/usr/bin/env bash
# deck - 管理 deck 服务（单一 backend，托管前端静态资源）
# 用法: deck <start|stop|restart|status|help|remove>

set -e

# DECK_ROOT: 安装目录，由 install.sh 设置或从脚本位置推导
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [ -n "$DECK_ROOT" ]; then
  ROOT="$DECK_ROOT"
elif [ -f "$SCRIPT_DIR/backend/package.json" ] && [ -f "$SCRIPT_DIR/app/package.json" ]; then
  # 脚本在 $INSTALL_DIR/deck，backend/app 与 deck 同目录
  ROOT="$SCRIPT_DIR"
elif [ -f "$SCRIPT_DIR/../backend/package.json" ] && [ -f "$SCRIPT_DIR/../app/package.json" ]; then
  # 脚本在 scripts/deck，项目根在上一级
  ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
else
  echo "错误: 无法定位 deck 安装目录，请设置 DECK_ROOT 环境变量" >&2
  exit 1
fi

DECK_ROOT="$ROOT"
ECOSYSTEM="$DECK_ROOT/ecosystem.config.cjs"
INSTALLED_SKILLS="$DECK_ROOT/.installed_skills"
if [ -f "$DECK_ROOT/.skills_target" ]; then
  SKILLS_TARGET="$(cat "$DECK_ROOT/.skills_target")"
else
  SKILLS_TARGET="${DECK_SKILLS_PATH:-$HOME/.openclaw/workspace/skills}"
fi

if [ -f "$DECK_ROOT/.deck_pkg" ]; then
  PKG="$(cat "$DECK_ROOT/.deck_pkg")"
else
  if command -v pnpm >/dev/null 2>&1; then
    PKG=pnpm
  elif command -v npm >/dev/null 2>&1; then
    PKG=npm
  else
    echo "错误: 未找到 pnpm 或 npm，请先安装" >&2
    exit 1
  fi
fi
if ! command -v "$PKG" >/dev/null 2>&1; then
  echo "错误: 包管理器 $PKG 不可用，请检查 PATH" >&2
  exit 1
fi

cmd_help() {
  cat <<'EOF'
deck - 管理 deck 服务

用法: deck <命令>

命令:
  start    启动 backend（同时托管前端静态资源）
  stop     停止 backend
  restart  重启 backend
  status   查看运行状态
  help     显示此帮助
  remove   停止服务、删除安装目录及已安装的 skills

示例:
  deck start
  deck status
  deck stop
EOF
}

ensure_pm2() {
  if command -v pm2 >/dev/null 2>&1; then
    return 0
  fi
  echo "未检测到 pm2，正在自动安装..."
  if [ "$PKG" = "pnpm" ]; then
    pnpm add -g pm2
  else
    npm install -g pm2
  fi
  if ! command -v pm2 >/dev/null 2>&1; then
    echo "错误: pm2 安装后仍不可用，请检查 PATH 或手动执行: npm install -g pm2" >&2
    exit 1
  fi
  echo "pm2 已安装完成。若后续 deck 命令异常，可尝试重新打开终端或执行: export PATH=\"\$(npm root -g)/../bin:\$PATH\""
}

ensure_build() {
  # backend: lazy install + build
  if [ ! -d "$DECK_ROOT/backend/node_modules" ]; then
    echo "正在为 backend 安装依赖并构建..."
    (cd "$DECK_ROOT/backend" && $PKG install && $PKG run build)
  elif [ ! -f "$DECK_ROOT/backend/dist/main.js" ]; then
    echo "backend 依赖已安装，仅构建 dist..."
    (cd "$DECK_ROOT/backend" && $PKG run build)
  fi

  # frontend: lazy install + build
  if [ ! -d "$DECK_ROOT/app/node_modules" ]; then
    echo "正在为 frontend 安装依赖并构建..."
    (cd "$DECK_ROOT/app" && $PKG install && $PKG run build)
  elif [ ! -d "$DECK_ROOT/app/dist" ]; then
    echo "frontend 依赖已安装，仅构建 dist..."
    (cd "$DECK_ROOT/app" && $PKG run build)
  fi
}

cmd_start() {
  ensure_pm2
  ensure_build
  if [ ! -f "$ECOSYSTEM" ]; then
    echo "错误: 未找到 ecosystem.config.cjs，请确保安装完整" >&2
    exit 1
  fi
  cd "$DECK_ROOT" && pm2 start ecosystem.config.cjs
  echo "deck 已启动"
}

cmd_stop() {
  ensure_pm2
  pm2 stop deck-backend 2>/dev/null || true
  echo "deck 已停止"
}

cmd_restart() {
  ensure_pm2
  ensure_build
  pm2 restart deck-backend 2>/dev/null || pm2 start "$ECOSYSTEM"
  echo "deck 已重启"
}

cmd_status() {
  ensure_pm2
  pm2 list 2>/dev/null | grep -E "deck-|App name" || pm2 list
}

remove_deck_from_path() {
  [ ! -f "$DECK_ROOT/.deck_install_method" ] && return
  method=$(cat "$DECK_ROOT/.deck_install_method")
  case "$method" in
    symlink:*)
      target="${method#symlink:}"
      if [ -L "$target" ]; then
        rm -f "$target"
        echo "已移除软链接: $target"
      fi
      ;;
    profile:*)
      files="${method#profile:}"
      IFS=',' read -ra arr <<< "$files"
      for f in "${arr[@]}"; do
        [ -z "$f" ] && continue
        f="${f/#\~/$HOME}"
        [ ! -f "$f" ] && continue
        grep -q "# === deck PATH (do not edit) ===" "$f" 2>/dev/null || continue
        if sed -i.bak '/# === deck PATH (do not edit) ===/,/# === end deck PATH ===/d' "$f" 2>/dev/null; then
          rm -f "${f}.bak"
          echo "已从 $f 移除 deck PATH"
        elif sed -i '' '/# === deck PATH (do not edit) ===/,/# === end deck PATH ===/d' "$f" 2>/dev/null; then
          echo "已从 $f 移除 deck PATH"
        fi
      done
      ;;
  esac
}

cmd_remove() {
  ensure_pm2
  echo "正在停止 deck 进程..."
  pm2 delete deck-backend 2>/dev/null || true
  if [ -f "$INSTALLED_SKILLS" ]; then
    echo "正在删除已安装的 skills..."
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      target="$SKILLS_TARGET/$name"
      if [ -d "$target" ]; then
        rm -rf "$target"
        echo "  已删除: $name"
      fi
    done < "$INSTALLED_SKILLS"
  fi
  remove_deck_from_path
  echo "正在删除 deck 安装目录: $DECK_ROOT"
  rm -rf "$DECK_ROOT"
  echo "deck 已完全移除"
}

case "${1:-help}" in
  start)   cmd_start ;;
  stop)    cmd_stop ;;
  restart) cmd_restart ;;
  status)  cmd_status ;;
  help)    cmd_help ;;
  remove)  cmd_remove ;;
  *)
    echo "未知命令: $1" >&2
    cmd_help
    exit 1
    ;;
esac
